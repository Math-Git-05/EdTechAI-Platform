SECRET_KEY=replace-with-a-strong-secret
SECURITY_PASSWORD_SALT=replace-with-a-random-salt
FLASK_CONFIG=production
DATABASE_URL=sqlite:///edtech.db
# Produccion (Supabase/Postgres) ejemplo:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/postgres?sslmode=require
# Para usar SQL Server con pyodbc (sin DATABASE_URL), completa:
# DB_SERVER=localhost
# DB_NAME=EdTech
# DB_DRIVER=ODBC Driver 17 for SQL Server
# DB_TRUSTED_CONNECTION=yes
# DB_TRUST_SERVER_CERTIFICATE=yes
DB_SERVER=
DB_NAME=
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_TRUSTED_CONNECTION=yes
DB_TRUST_SERVER_CERTIFICATE=yes

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-email@gmail.com

APP_BASE_URL=http://192.168.100.119:5000/
TALLY_FORM_ID=kdAYAM
TALLY_API_KEY=
TALLY_WEBHOOK_SECRET=
TALLY_SUBMISSIONS_SHEET_URL=https://docs.google.com/spreadsheets/d/1BH2w7FbiSbkGV2VjkIydHgYyG9uF5HOlng28Mzm7JHw/edit?usp=sharing
SEED_TEST_USERS=false
ENABLE_STUDENT_DATA_SHADOW_SYNC=false
ENABLE_FORM_RESPONSE_STORAGE=false
