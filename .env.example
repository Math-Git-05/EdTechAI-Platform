FLASK_CONFIG=production

# Seguridad de aplicación
SECRET_KEY=REEMPLAZAR_SECRET_KEY_LARGO
SECURITY_PASSWORD_SALT=REEMPLAZAR_SECURITY_PASSWORD_SALT

# Base de datos (Render/Supabase)
DATABASE_URL=postgresql://postgres:REEMPLAZAR_PASSWORD@db.REEMPLAZAR_PROJECT_REF.supabase.co:5432/postgres

# SQL Server local (opcional si no usas DATABASE_URL)
# DB_SERVER=localhost
# DB_NAME=EdTech
# DB_DRIVER=ODBC Driver 17 for SQL Server
# DB_TRUSTED_CONNECTION=yes
# DB_TRUST_SERVER_CERTIFICATE=yes

# SMTP (se aceptan MAIL_* y SMTP_* como alias)
MAIL_SERVER=mail.smtp2go.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=REEMPLAZAR_SMTP_USER
MAIL_PASSWORD=REEMPLAZAR_SMTP_PASS
MAIL_FROM=noreply@edtechai.lat

# Alias opcionales (si prefieres usar la nomenclatura SMTP_*)
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=587
SMTP_USER=REEMPLAZAR_SMTP_USER
SMTP_PASS=REEMPLAZAR_SMTP_PASS
SMTP_FROM=noreply@edtechai.lat

# Remitentes por tipo de mensaje
MAIL_FROM_NOREPLY=noreply@edtechai.lat
MAIL_FROM_SUPPORT=support@edtechai.lat
MAIL_REPLY_TO_SUPPORT=support@edtechai.lat
MAIL_BRAND_NAME=EdTech AI

# URL pública del sitio
APP_BASE_URL=https://techai.lat

# Integración Tally
TALLY_FORM_ID=REEMPLAZAR_TALLY_FORM_ID
TALLY_API_KEY=REEMPLAZAR_TALLY_API_KEY
TALLY_WEBHOOK_SECRET=REEMPLAZAR_TALLY_WEBHOOK_SECRET
TALLY_SUBMISSIONS_SHEET_URL=REEMPLAZAR_URL_HOJA_SUBMISSIONS

# Banderas
SEED_TEST_USERS=false
ENABLE_STUDENT_DATA_SHADOW_SYNC=false
ENABLE_FORM_RESPONSE_STORAGE=false
DROP_DEPRECATED_TABLES=false
